# ==============================================
# Math Tutor - 环境配置
# ==============================================

# LLM 配置（默认指向本地 LMStudio + Qwen3）
LLM_API_BASE=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=qwen3.6-35b-a3b
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=8192
LLM_REQUEST_TIMEOUT=180

# 可选：传给 OpenAI 客户端的 extra_body（必须是 JSON 字符串）
# 启用 Qwen3 的思考模式（不带工具时可用；带工具时建议关闭，下面那个开关已自动处理）：
# LLM_EXTRA_BODY={"chat_template_kwargs":{"enable_thinking":true}}
LLM_EXTRA_BODY=

# 调工具时自动设置 enable_thinking=false（默认 true，强烈建议保留）。
# Qwen3 思考模式遇到工具会"想很久不出 tool_call" 或者把 LMStudio chat template 弄崩成 502。
# 如果你确认你的模型/部署能正确处理思考+工具，再设为 false。
LLM_DISABLE_THINKING_WITH_TOOLS=true

# Agent 在工具调用之间的"思考预算"上限。默认 2048 已经够用，避免在每个工具间花很长时间想"我现在要调用 X"。
# 工具内部 LLM 调用有各自的 max_tokens（更大），不受这个影响。
LLM_AGENT_LOOP_MAX_TOKENS=2048

# 单个工具的最大执行时间（秒）。35B 量化模型 + 思考模式 + 8K max_tokens 生成 Manim 代码可能需要 2-3 分钟。
# 如果你看到 "工具 generate_manim_code 超时"，把这个调大或换更快的模型。
LLM_TOOL_TIMEOUT_S=300

# === 快速 LLM（analyze / solve / match_skill 兜底用）===
# 留空 = 用主 LLM。设小模型可加速这几个轻量调用（生成 Manim 代码仍用主 LLM）。
# 推荐：Qwen3-4B / Qwen3-8B / 任何 OpenAI 兼容小模型
# 例：另起一个 LMStudio 实例跑 4B，监听 1240 端口
LLM_FAST_API_BASE=
LLM_FAST_API_KEY=
LLM_FAST_MODEL=

# === 视觉模型（inspect_video 工具用）===
# 留空时自动 fallback 到上面的主 LLM endpoint（适合 Qwen-VL 这类同时支持文本+图像的模型）。
# 想用独立的 VL 模型时填这三个：
LLM_VISION_API_BASE=
LLM_VISION_API_KEY=
LLM_VISION_MODEL=

# === Embedding 模型（语义检索 skills / patterns / examples 用）===
# 留 LLM_EMBEDDING_MODEL 为空时禁用语义检索，回退到关键词 substring。
# 推荐本地选项：
#   - LMStudio 加载 bge-small-zh / bge-m3 / qwen3-embedding 等
#   - Ollama:    ollama pull bge-m3 → http://localhost:11434/v1
#   - TEI:       text-embeddings-inference (HuggingFace) → http://localhost:8080
LLM_EMBEDDING_API_BASE=
LLM_EMBEDDING_API_KEY=
LLM_EMBEDDING_MODEL=
# 维度：0 = 让 endpoint 决定（默认）；某些 OpenAI 模型支持指定 (text-embedding-3-* 用 1536 / 3072 等)
LLM_EMBEDDING_DIMENSION=0

# === Reranker 模型（embedding 检索后的精排）===
# 二阶段检索：embedding 先粗排 top-N，rerank 在这 N 个里精排出真正的 top-K。
# 推荐本地选项：
#   - infinity:  https://github.com/michaelfeil/infinity（OpenAI/Cohere 兼容 → cohere）
#   - TEI:       text-embeddings-inference 加载 reranker 模型 → tei
#   - 自建 server 加载 bge-reranker-v2-m3 / bge-reranker-large 等
# 设 LLM_RERANK_ENABLED=false 可保留配置但关掉精排（debug / A-B 用）。
LLM_RERANK_API_BASE=
LLM_RERANK_API_KEY=
LLM_RERANK_MODEL=
LLM_RERANK_API_TYPE=cohere    # cohere（含 infinity / Jina）或 tei
LLM_RERANK_ENABLED=true       # 即使配了 model，也可在此关闭
LLM_RERANK_POOL_SIZE=10       # embedding 先取这么多候选，rerank 再精排到 top_k

# Manim 配置
MANIM_OUTPUT_DIR=./media
MANIM_QUALITY=low                  # low / medium / high
MANIM_USE_LATEX=false

# 存储（SQLite + 文件归档）
DATA_DIR=./data
# DB_PATH 留空时自动取 {DATA_DIR}/math_tutor.sqlite
DB_PATH=

# API 配置
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# CORS（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ==============================================
# 切换到其他 OpenAI 兼容端点示例
# ==============================================
# LMStudio (默认)：              http://localhost:1234/v1
# Ollama (OpenAI shim)：         http://localhost:11434/v1
# vLLM：                         http://localhost:8000/v1
# DeepSeek 云端：                https://api.deepseek.com  + key
